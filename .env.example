# ========================================
# Example runtime environment
# Copy to .env and fill in real values.
# ========================================

# Core endpoints used by orchestrator
# Default for local laptop mode: point these to your remote GPU model API.
# If running model API on this same machine, use http://localhost:8000.
VLM_API_URL=http://your-gpu-server:8000
AUDIO_API_URL=http://your-gpu-server:8000

# API keys (required for planner/controller + model downloads)
GROQ_API_KEY=your_groq_api_key_here
HF_TOKEN=your_huggingface_token_here

# Model selection
VLM_MODEL_NAME=Qwen/Qwen2-VL-2B-Instruct
PERCEPTION_MODEL=Qwen/Qwen2-VL-2B-Instruct
PLANNER_MODEL=Qwen/Qwen2.5-7B-Instruct
EXECUTION_MODEL=facebook/audiogen-medium
VERIFICATION_MODEL=laion/clap-htsat-fused
VERIFICATION_MODEL_SECONDARY=laion/larger_clap_general

# Perception and timeline controls
MAX_PERCEPTION_FRAMES=12
PERCEPTION_CENTER_CROP=1
PERCEPTION_RESIZE_TO=512
MAX_VIDEO_SECONDS=15
PROMPT_ONLY_DURATION_SEC=6

# Agentic behavior controls
SELF_CONSISTENCY_RUNS=3
CROSS_MODAL_AGREEMENT_THRESHOLD=0.35
VERIFIER_GAP_DELTA=0.25

# Runtime performance controls
OFFLOAD_AFTER_USE=1
WARMUP_ON_START=0

# Optional frontend env (web/.env.local)
# NEXT_PUBLIC_AGENT_WS_URL=ws://localhost:8010/ws/foley
# NEXT_PUBLIC_AGENT_API_URL=http://localhost:8010
